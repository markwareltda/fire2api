# Fire2API runtime
APP_ENV=production
API_DEBUG=false
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Chave estatica unica. Use pelo menos 32 caracteres aleatorios.
ADMIN_API_KEY=replace-with-at-least-32-random-characters

# Firebird 3, 4 ou 5
FIREBIRD_USER=fire2api_api
FIREBIRD_PASSWORD=replace-with-a-database-password
FIREBIRD_HOST=firebird.example.internal
FIREBIRD_PORT=3050
FIREBIRD_DB_PATH=/firebird/data/APP.FDB
FIREBIRD_CHARSET=UTF8
FIREBIRD_POOL_SIZE=8
FIREBIRD_MAX_OVERFLOW=16

# Metastore SQLite persistente
SQLITE_DB_PATH=data/metastore.db
SQLITE_BUSY_TIMEOUT_MS=5000

# Execucao e limites
QUERY_MAX_CONCURRENCY_GLOBAL=8
QUERY_MAX_CONCURRENCY_PER_TOKEN=2
QUERY_ACQUIRE_TIMEOUT_MS=300
QUERY_TIMEOUT_SECONDS=60
QUERY_TIMEOUT_MAX_SECONDS=180
QUERY_CANCEL_ON_CLIENT_DISCONNECT=true
QUERY_MAX_ROWS_HARD=1000
QUERY_FETCH_CHUNK_SIZE=200
QUERY_HISTORY_SIZE=500
MAX_REQUEST_BODY_BYTES=1048576
IDEMPOTENCY_TTL_HOURS=24
ADMIN_SESSION_MINUTES=30
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_LOCKOUT_SECONDS=300

# Lista separada por virgulas. Vazio desabilita CORS cross-origin.
CORS_ALLOWED_ORIGINS=
